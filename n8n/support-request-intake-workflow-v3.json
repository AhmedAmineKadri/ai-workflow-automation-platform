      "id": "cf7b062e-f9ee-45ed-8d98-f8b020b4c5e3",
      "name": "Respond to Webhook"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:11434/api/chat",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama3.2:3b\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an AI assistant inside a customer support automation workflow. Your task is to analyze one customer support request. Return only valid JSON. Do not use markdown. Do not wrap the JSON in backticks. Do not add explanations. The JSON object must contain exactly these fields: category, priority, summary, extractedData, suggestedReply. priority must be one of: low, medium, high. category should be a short snake_case label such as damaged_product, refund_request, delivery_issue, technical_problem, account_access, billing_issue, or general_question. summary must be one short sentence for an internal support agent. extractedData must be a JSON object. suggestedReply must be polite, short, and must not promise refunds, replacements, or legal actions. The reply should say the request will be reviewed by the support team.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Customer name: {{$json.customerName}}\\nCustomer email: {{$json.email}}\\nCustomer message: {{$json.message}}\"\n    }\n  ],\n  \"stream\": false,\n  \"format\": \"json\",\n  \"options\": {\n    \"temperature\": 0.1\n  }\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        832,
        0
      ],
      "id": "13c3bfb9-6884-4aa7-b210-50ed5dd59aa0",
      "name": "Ollama - Analyze Request"
    },
    {
      "parameters": {
        "jsCode": "const validatedInput = $('Code - Validate Input').first().json;\nconst ollamaResponse = $input.first().json;\n\nconst rawContent = ollamaResponse.message?.content || \"\";\n\nlet aiResult;\n\ntry {\n  aiResult = JSON.parse(rawContent);\n} catch (error) {\n  aiResult = {\n    category: \"unknown\",\n    priority: \"medium\",\n    summary: \"AI response could not be parsed as valid JSON.\",\n    extractedData: {\n      rawResponse: rawContent,\n      parseError: error.message\n    },\n    suggestedReply: \"Thank you for your message. Your request will be reviewed by our support team.\"\n  };\n}\n\nconst allowedPriorities = [\"low\", \"medium\", \"high\"];\n\nconst priority = allowedPriorities.includes(aiResult.priority)\n  ? aiResult.priority\n  : \"medium\";\n\nreturn [\n  {\n    json: {\n      customer_name: validatedInput.customerName,\n      customer_email: validatedInput.email,\n      message: validatedInput.message,\n\n      category: aiResult.category || \"unknown\",\n      priority,\n      summary: aiResult.summary || \"No summary generated.\",\n      extracted_data: JSON.stringify(aiResult.extractedData || {}),\n      suggested_reply: aiResult.suggestedReply || \"Thank you for your message. Your request will be reviewed by our support team.\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        0
      ],
      "id": "bac746ef-e3d2-45b7-a6b4-9d9fc909052b",
      "name": "Code - Parse AI Result"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\n\nconst errors = [];\n\nif (!body.customerName || body.customerName.trim().length === 0) {\n  errors.push(\"customerName is required\");\n}\n\nif (!body.email || body.email.trim().length === 0) {\n  errors.push(\"email is required\");\n}\n\nif (!body.message || body.message.trim().length === 0) {\n  errors.push(\"message is required\");\n}\n\nif (body.message && body.message.trim().length < 10) {\n  errors.push(\"message must be at least 10 characters long\");\n}\n\nreturn [\n  {\n    json: {\n      valid: errors.length === 0,\n      errors,\n      customerName: body.customerName,\n      email: body.email,\n      message: body.message\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
