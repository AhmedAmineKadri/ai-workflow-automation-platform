    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nreturn [\n  {\n    json: {\n      status: \"error\",\n      message: \"Request is not pending approval or does not exist.\",\n      requestId: input.requestId,\n      currentStatus: input.currentStatus || null,\n      errors: input.errors\n    }\n  }\n];"
      },
