      "id": "0400d00f-cd75-4328-adf6-4e75e2250e32",
      "name": "Respond - Review Error"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE app.support_requests\nSET\n    approval_status = '{{ $json.decision }}',\n    reviewed_by = '{{ $json.reviewedBy.replaceAll(\"'\", \"''\") }}',\n    review_comment = '{{ $json.comment.replaceAll(\"'\", \"''\") }}',\n    reviewed_at = NOW(),\n    updated_at = NOW()\nWHERE id = {{ $json.requestId }}\n  AND approval_status = 'PENDING_APPROVAL'\nRETURNING\n    id,\n    customer_name,\n    customer_email,\n    approval_status,\n    reviewed_by,\n    review_comment,\n    reviewed_at;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
