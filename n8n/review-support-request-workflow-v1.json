            {
              "id": "191e7fa3-1a3c-43bd-9a0b-806fee55ad81",
              "leftValue": "={{ $json.canReview }}",
              "rightValue": "YES",
              "operator": {
                "type": "string",
                "operation": "equals",
                "name": "filter.operator.equals"
              }
            }
          ],
