      ],
      "id": "09f4dbd1-8ef6-42da-8e32-8be6df4e93dd",
      "name": "Code - Build Review Success Response"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    {{ $json.requestId }}::BIGINT AS request_id,\n    EXISTS (\n        SELECT 1\n        FROM app.support_requests\n        WHERE id = {{ $json.requestId }}\n    ) AS request_exists,\n    (\n        SELECT approval_status\n        FROM app.support_requests\n        WHERE id = {{ $json.requestId }}\n    ) AS current_status;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        672,
        -208
      ],
      "id": "616c2f2f-367c-4446-b962-4c7a1e2a06bd",
      "name": "PostgreSQL - Check Request Status",
      "credentials": {
        "postgres": {
          "id": "E1wA7DwtUNdE6OwO",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const reviewInput = $('Code - Validate Review Input').first().json;\nconst dbResult = $input.first().json;\n\nconst errors = [];\n\nif (!dbResult.request_exists) {\n  errors.push(\"requestId does not exist\");\n} else if (dbResult.current_status !== \"PENDING_APPROVAL\") {\n  errors.push(`request is already ${dbResult.current_status}`);\n}\n\nconst canReview = errors.length === 0 ? \"YES\" : \"NO\";\n\nreturn [\n  {\n    json: {\n      ...reviewInput,\n      requestExists: dbResult.request_exists,\n      currentStatus: dbResult.current_status,\n      canReview,\n      errors\n    }\n  }\n];"
      },
