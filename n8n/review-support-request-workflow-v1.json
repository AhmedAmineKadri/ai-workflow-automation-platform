{
  "name": "Review Support Request Workflow v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "review-request",
        "responseMode": "responseNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        0,
        0
      ],
      "id": "8d521a99-bd83-41d1-bf58-5ef7d7e63ac7",
      "name": "Webhook",
      "webhookId": "7ff63ce6-1546-4fce-a61e-43fc54cffe1f"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || {};\n\nconst errors = [];\n\nconst requestId = Number(body.requestId);\n\nconst rawDecision = typeof body.decision === \"string\"\n  ? body.decision.trim()\n  : \"\";\n\nconst decision = rawDecision.toUpperCase();\n\nconst reviewedBy = typeof body.reviewedBy === \"string\"\n  ? body.reviewedBy.trim()\n  : \"\";\n\nconst comment = typeof body.comment === \"string\"\n  ? body.comment.trim()\n  : \"\";\n\nif (!Number.isInteger(requestId) || requestId <= 0) {\n  errors.push(\"requestId must be a positive integer\");\n}\n\nif (!rawDecision) {\n  errors.push(\"decision is required\");\n} else if (![\"APPROVED\", \"REJECTED\"].includes(decision)) {\n  errors.push(\"decision must be APPROVED or REJECTED\");\n}\n\nif (!reviewedBy) {\n  errors.push(\"reviewedBy is required\");\n}\n\nif (comment.length > 1000) {\n  errors.push(\"comment must not be longer than 1000 characters\");\n}\n\nconst validationStatus = errors.length === 0 ? \"VALID\" : \"INVALID\";\n\nreturn [\n  {\n    json: {\n      valid: errors.length === 0,\n      validationStatus,\n      errors,\n      requestId,\n      decision,\n      reviewedBy,\n      comment\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ],
      "id": "27f302ef-bf77-4dc0-92b1-2fe82e9d33cc",
      "name": "Code - Validate Review Input"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 3
          },
          "conditions": [
            {
              "id": "b9ea137f-29b1-45a1-a70c-bc270564e7a1",
              "leftValue": "={{ $json.validationStatus }}",
              "rightValue": "VALID",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "looseTypeValidation": true,
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        384,
        0
      ],
      "id": "def344e6-4a6c-475a-b96e-b88e33fd3dcb",
      "name": "IF - Is Review Input Valid?"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nreturn [\n  {\n    json: {\n      status: \"error\",\n      message: \"Invalid review request input.\",\n      errors: input.errors\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        96
      ],
      "id": "7edb1e2e-7e44-43c3-9b13-443d02c73467",
      "name": "Code - Build Review Error Response"
