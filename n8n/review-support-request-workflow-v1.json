    },
    {
      "parameters": {
        "jsCode": "const reviewInput = $('Code - Validate Review Input').first().json;\n\nreturn [\n  {\n    json: {\n      status: \"success\",\n      message: \"Review decision was saved successfully.\",\n      requestId: reviewInput.requestId,\n      decision: reviewInput.decision,\n      reviewedBy: reviewInput.reviewedBy\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
